.bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
}
.filters {
  white-space: nowrap;
  flex: 1;
}
.chip {
  display: inline-block;
  padding: 8rpx 24rpx;
  margin-right: 12rpx;
  background: #eef0f3;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #555;
}
.chip.on {
  background: #1f6feb;
  color: #fff;
}
.fav-link {
  color: #1f6feb;
  font-size: 28rpx;
  padding-left: 16rpx;
}
.tip {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
}
.card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}
.type {
  color: #1f6feb;
}
.tag-kid {
  background: #ffe9c2;
  color: #a85b00;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  font-size: 22rpx;
}
.price {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #e4572e;
}
