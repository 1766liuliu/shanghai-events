<view class="bar">
  <scroll-view scroll-x class="filters">
    <view class="chip {{type==''?'on':''}}" bindtap="setType" data-type="">全部</view>
    <view class="chip {{type=='演出'?'on':''}}" bindtap="setType" data-type="演出">演出</view>
    <view class="chip {{type=='展会'?'on':''}}" bindtap="setType" data-type="展会">展会</view>
    <view class="chip {{type=='体育'?'on':''}}" bindtap="setType" data-type="体育">体育</view>
    <view class="chip {{kidOnly?'on':''}}" bindtap="toggleKid">亲子</view>
  </scroll-view>
  <view class="fav-link" bindtap="goFav">收藏</view>
</view>

<view wx:if="{{loading}}" class="tip">加载中…</view>
<view wx:elif="{{events.length==0}}" class="tip">暂无数据，请先运行采集层写入云库</view>

<view
  wx:for="{{events}}"
  wx:key="_id"
  class="card"
  bindtap="openDetail"
  data-id="{{item._id}}"
>
  <view class="title">{{item.title}}</view>
  <view class="meta">
    <text wx:if="{{item.kid_friendly}}" class="tag-kid">亲子</text>
    <text class="type">{{item.type}}</text>
    <text wx:if="{{item.start_date}}"> · {{item.start_date}}</text>
    <text wx:if="{{item.venue}}"> · {{item.venue}}</text>
  </view>
  <view wx:if="{{item.price_range}}" class="price">{{item.price_range}}</view>
</view>
