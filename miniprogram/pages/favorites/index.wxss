  color: #999;
}
.card {
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}
.type {
  color: #1f6feb;
}
.tag-kid {
  background: #ffe9c2;
  color: #a85b00;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  font-size: 22rpx;
}
